rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.email == "machadofabio@gmail.com";
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Flag booleana no doc settings/{uid} do próprio usuário (ex.: dpEditor,
    // comprasEditor). Só admin escreve settings, então a flag é confiável.
    function hasSettingFlag(flag) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/settings/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/settings/$(request.auth.uid)).data.get(flag, false) == true;
    }

    function isDpEditor() {
      return isAdmin() || hasSettingFlag('dpEditor');
    }

    function isComprasEditor() {
      return isAdmin() || hasSettingFlag('comprasEditor');
    }

    // Usuários: qualquer logado lê. Cada um cria o seu (sem se auto-aprovar)
    // e atualiza só perfil; admin pode tudo (aprovar/rejeitar/deletar).
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && (
        isAdmin() || request.resource.data.get('approved', false) == false
      );
      allow update: if isAdmin() ||
        (isOwner(uid) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved']));
      allow delete: if isAdmin();
    }

    // Tarefas: dono lê/escreve as suas, admin lê/escreve todas
    match /tasks/{uid}/items/{taskId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Chat: dono da sala lê/escreve, admin lê/escreve todas
    match /chats/{roomId}/messages/{messageId} {
      allow read, write: if isOwner(roomId) || isAdmin();
    }

    // Notas: dono lê/escreve as suas, admin lê/escreve todas
    match /notes/{noteId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if resource.data.uid == request.auth.uid || isAdmin();
    }

    // Lembretes (post-its do calendário): dono lê/escreve os seus, admin todos
    match /stickyNotes/{noteId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if resource.data.uid == request.auth.uid || isAdmin();
    }

    // Ideias: qualquer logado lê e cria, admin pode tudo
    match /ideas/{ideaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Roteiros: qualquer logado lê, cria e edita; admin deleta
    match /scripts/{scriptId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Reels: qualquer logado lê, cria e arquiva; admin aprova/deleta
    match /reels/{reelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Content Plan: qualquer logado lê/cria/edita/deleta (admin gerencia status)
    match /contentPlan/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Influencers: qualquer logado lê/cria/edita; admin deleta
    match /influencers/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Avaliações: qualquer logado lê e cria, admin pode tudo
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Mensagens admin: qualquer logado lê; admin cria/deleta;
    // usuário comum pode atualizar apenas readBy (marcar como lida) sem remover ninguém.
    match /adminMessages/{msgId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
        request.resource.data.readBy.hasAll(resource.data.readBy) &&
        request.auth.uid in request.resource.data.readBy
      );
    }

    // Configurações: dono lê as suas, admin lê/escreve todas.
    // settings/global é lido por qualquer logado (ordem do menu, etc).
    match /settings/{uid} {
      allow read: if isOwner(uid) || isAdmin() || uid == 'global';
      allow write: if isAdmin();
    }

    // Base de conhecimento: qualquer logado lê, admin escreve
    match /knowledge/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Departamento Pessoal (lojas, funcionários e escala de faltas):
    // qualquer logado lê (visibilidade controlada por toggle/loja no cliente);
    // só admin ou editor (settings.dpEditor) escreve.
    match /dpStores/{storeId} {
      allow read: if isSignedIn();
      allow write: if isDpEditor();
    }
    match /dpEmployees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isDpEditor();
    }
    match /dpAbsences/{absenceId} {
      allow read: if isSignedIn();
      allow write: if isDpEditor();
    }
    // Salários (dado sensível): leitura só para admin ou quem tem a flag
    // dpSalariosVisible; escrita só admin (inclui o script de importação, que
    // usa o Firebase Admin SDK e ignora estas regras).
    match /dpSalarios/{salarioId} {
      allow read: if isAdmin() || hasSettingFlag('dpSalariosVisible');
      allow write: if isAdmin();
    }

    // Compras: qualquer logado lê. O catálogo (fornecedores e cadastro de itens)
    // é só de admin/editor; mas qualquer logado pode ajustar a quantidade do
    // pedido (campo qty) — por isso update de comprasItens libera alteração
    // exclusiva de qty para não-editores.
    match /comprasFornecedores/{fornecedorId} {
      allow read: if isSignedIn();
      allow write: if isComprasEditor();
    }
    match /comprasItens/{itemId} {
      allow read: if isSignedIn();
      allow create, delete: if isComprasEditor();
      allow update: if isComprasEditor() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['qty'])
      );
    }

    // CMV (fichas técnicas): beneficiados e sabores. Qualquer logado lê;
    // só admin/editor de compras escreve (mesma alçada do catálogo de Preços/Compras).
    match /cmvBeneficiados/{id} {
      allow read: if isSignedIn();
      allow write: if isComprasEditor();
    }
    match /cmvSabores/{id} {
      allow read: if isSignedIn();
      allow write: if isComprasEditor();
    }
  }
}
