# Credenciais do deploy FTP (npm run deploy:ftp).
# Copie este arquivo para .env.ftp e preencha. O .env.ftp esta no .gitignore —
# a senha NUNCA vai para o git.

FTP_HOST=ftp.damepizza.com.br
FTP_USER=seu_usuario
FTP_PASSWORD=sua_senha

# Pasta remota onde o portal fica. Em hospedagem cPanel costuma ser
# /public_html/intranet. Confirme no seu painel qual e a raiz web.
FTP_DIR=/public_html/intranet

# FTPS explicito (TLS). Deixe true se o host exigir conexao segura.
FTP_SECURE=false

# Porta FTP (padrao 21).
FTP_PORT=21

# true = apaga a pasta remota antes de subir (deixa o servidor limpo, mas pode
# quebrar por segundos quem estiver com a pagina aberta). false = so sobrescreve.
FTP_CLEAN=false
